# FocoContext V0.1 local deployment env.
# Copy this file to .env and fill secrets before running Docker Compose.
# Default tenant, account, and project IDs are generated by the database seed flow.

# Runtime ports
# Docker Compose host bind address for published ports. Keep 127.0.0.1
# for reverse-proxy deployments; use 0.0.0.0 only for intentional direct exposure.
FOCOCONTEXT_BIND_HOST=127.0.0.1
FOCOCONTEXT_API_PORT=18080
FOCOCONTEXT_ADMIN_PORT=18081
FOCOCONTEXT_POSTGRES_PORT=18432
FOCOCONTEXT_REDIS_PORT=18379

# Release image deployment.
# Required when using docker-compose.example.yml. Use the Git release tag
# without the leading "v", for example v0.1.0 -> 0.1.0.
FOCOCONTEXT_IMAGE_TAG=0.1.0
# Public GHCR image namespace. Override only when using a custom registry.
FOCOCONTEXT_IMAGE_NAMESPACE=ghcr.io/farozerolabs

# Admin account
FOCOCONTEXT_ADMIN_USERNAME=admin
FOCOCONTEXT_ADMIN_PASSWORD=<set-admin-password>
FOCOCONTEXT_ADMIN_SESSION_TTL_SECONDS=604800

# Public API access.
# For reverse-proxy deployments, set these to the public domains, for example:
# FOCOCONTEXT_CORS_ORIGINS=https://foco.example.com
# FOCOCONTEXT_ADMIN_API_BASE_URL=https://api.example.com/v1
# FOCOCONTEXT_ADMIN_BASE_URL=https://foco.example.com
FOCOCONTEXT_API_KEY=<set-random-api-key>
FOCOCONTEXT_CORS_ORIGINS=http://localhost:18081,http://127.0.0.1:18081
FOCOCONTEXT_ADMIN_API_BASE_URL=http://localhost:18080/v1
FOCOCONTEXT_ADMIN_BASE_URL=http://localhost:18081

# Source Watch mounted directory.
# Create rules with location `/source-watch` or a child path inside it.
FOCOCONTEXT_SOURCE_WATCH_HOST_DIR=./examples/source-watch
FOCOCONTEXT_SOURCE_WATCH_CONTAINER_DIR=/source-watch

# Source Watch URL list adapter.
SOURCE_WATCH_URL_LIST_ENABLED=false
SOURCE_WATCH_URL_LIST_PROTOCOLS=http,https
SOURCE_WATCH_URL_LIST_MAX_URLS=100
SOURCE_WATCH_URL_LIST_MAX_RESPONSE_BYTES=1048576
SOURCE_WATCH_URL_LIST_TIMEOUT_SECONDS=15
SOURCE_WATCH_URL_LIST_REDIRECT_LIMIT=3
SOURCE_WATCH_URL_LIST_MAX_RETRIES=2
SOURCE_WATCH_URL_LIST_RETRY_BASE_DELAY_MS=500
SOURCE_WATCH_URL_LIST_CONCURRENCY=2

# Source Watch S3 adapter. These credentials are for user source buckets,
# separate from the service's own object-storage S3 settings above.
SOURCE_WATCH_S3_ENABLED=false
SOURCE_WATCH_S3_ENDPOINT=
SOURCE_WATCH_S3_REGION=
SOURCE_WATCH_S3_BUCKET=
SOURCE_WATCH_S3_ACCESS_KEY_ID=
SOURCE_WATCH_S3_SECRET_ACCESS_KEY=
SOURCE_WATCH_S3_FORCE_PATH_STYLE=true
SOURCE_WATCH_S3_MAX_OBJECTS=1000
SOURCE_WATCH_S3_MAX_OBJECT_BYTES=20971520
SOURCE_WATCH_S3_TIMEOUT_SECONDS=30
SOURCE_WATCH_S3_MAX_RETRIES=2
SOURCE_WATCH_S3_RETRY_BASE_DELAY_MS=500
SOURCE_WATCH_S3_CONCURRENCY=2
SOURCE_WATCH_S3_INCREMENTAL_SCAN_ENABLED=true

# Source Watch Git adapter.
SOURCE_WATCH_GIT_ENABLED=false
SOURCE_WATCH_GIT_PROTOCOLS=https
SOURCE_WATCH_GIT_TOKEN=
SOURCE_WATCH_GIT_CLONE_DEPTH=1
SOURCE_WATCH_GIT_TEMP_DIR=/tmp/fococontext-git-watch
SOURCE_WATCH_GIT_MAX_FILES=2000
SOURCE_WATCH_GIT_MAX_FILE_BYTES=20971520
SOURCE_WATCH_GIT_TIMEOUT_SECONDS=60
SOURCE_WATCH_GIT_MAX_RETRIES=1
SOURCE_WATCH_GIT_RETRY_BASE_DELAY_MS=1000
SOURCE_WATCH_GIT_CONCURRENCY=2

# PostgreSQL
# Required durable production database. API and Worker do not fall back to in-memory repositories.
POSTGRES_USER=fococontext
POSTGRES_PASSWORD=<set-postgres-password>
POSTGRES_DB=fococontext
DATABASE_URL=postgresql://fococontext:<set-postgres-password>@postgres:5432/fococontext

# Redis
# Required for BullMQ queues, Admin sessions, runtime cache, runtime metrics, and pressure state.
REDIS_URL=redis://redis:6379

# S3-compatible object storage
# Configure an external or managed S3-compatible service for source objects and worker artifacts.
S3_PROVIDER_NAME=<set-s3-provider-name>
S3_ENDPOINT=<set-s3-endpoint>
S3_REGION=<set-s3-region>
S3_BUCKET=<set-s3-bucket>
S3_ACCESS_KEY_ID=<set-s3-access-key>
S3_SECRET_ACCESS_KEY=<set-s3-secret-key>
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=
S3_OPERATION_METRICS_ENABLED=true
S3_OPERATION_PRESSURE_WARNINGS_ENABLED=true
S3_OPERATION_METRICS_WINDOW_SECONDS=300
S3_OPERATION_CLASS_A_WARNING_THRESHOLD=1000
S3_OPERATION_CLASS_B_WARNING_THRESHOLD=10000
S3_PREVIEW_CACHE_ENABLED=true
S3_PREVIEW_MAX_CHARS=200000
S3_MULTIPART_PART_SIZE_BYTES=16777216

# OpenAI-compatible Chat provider
CHAT_PROVIDER_NAME=<set-chat-provider-name>
CHAT_BASE_URL=<set-chat-base-url>
CHAT_API_KEY=<set-chat-api-key>
CHAT_DEFAULT_MODEL=<set-chat-default-model>
CHAT_ANALYSIS_MODEL=<set-chat-analysis-model>
CHAT_GENERATION_MODEL=<set-chat-generation-model>
CHAT_MERGE_MODEL=<set-chat-merge-model>
CHAT_REQUEST_MAX_RETRIES=2

# OpenAI-compatible Embedding provider
EMBEDDING_PROVIDER_NAME=<set-embedding-provider-name>
EMBEDDING_BASE_URL=<set-embedding-base-url>
EMBEDDING_API_KEY=<set-embedding-api-key>
EMBEDDING_MODEL=<set-embedding-model>
EMBEDDING_DIMENSIONS=1536

# Optional Rerank provider.
# Leave all four RERANK_* values empty to disable rerank.
# Configure all four values together to enable optional Retrieve reranking.
# Partial RERANK_* configuration is invalid.
RERANK_PROVIDER_NAME=
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=

# Optional OpenAI-compatible Vision Caption provider.
# Leave VISION_CAPTION_ENABLED=false when image captioning is not configured.
VISION_CAPTION_ENABLED=false
VISION_CAPTION_PROVIDER_NAME=
VISION_CAPTION_BASE_URL=
VISION_CAPTION_API_KEY=
VISION_CAPTION_MODEL=
VISION_CAPTION_MAX_RETRIES=2
VISION_CAPTION_RETRY_BASE_DELAY_MS=500
VISION_CAPTION_CONCURRENCY=1
VISION_CAPTION_IMAGE_CONCURRENCY=1
VISION_CAPTION_TIMEOUT_SECONDS=60
VISION_CAPTION_MAX_IMAGES_PER_DOCUMENT=100
VISION_CAPTION_CONTEXT_CHARS=200
VISION_CAPTION_MAX_OUTPUT_TOKENS=160

# Bundled RapidOCR sidecar for scanned or low-text PDFs.
# The default Compose template starts OCR with `docker compose up -d`.
# Set OCR_ENABLED=false when OCR is intentionally disabled or use
# docker-compose.optional-ocr.example.yml for constrained hosts.
OCR_ENABLED=true
OCR_PROVIDER=rapidocr
OCR_SERVICE_BASE_URL=http://ocr-service:18082
OCR_SERVICE_API_KEY=
OCR_LANGS=ch,en
OCR_PAGE_DPI=180
OCR_MAX_PAGES_PER_DOCUMENT=200
OCR_MAX_PAGE_PIXELS=20000000
OCR_CONCURRENCY=1
OCR_PAGE_CONCURRENCY=1
OCR_TIMEOUT_SECONDS=60
OCR_MAX_RETRIES=2
OCR_RETRY_BASE_DELAY_MS=500
OCR_MIN_TEXT_CHARS_PER_PAGE=80
OCR_CONFIDENCE_THRESHOLD=0.5
OCR_STORE_PAGE_IMAGES=false

# Async deletion cleanup queue.
# Leave operation retention empty to keep compact cleanup summaries indefinitely.
DELETION_CLEANUP_CONCURRENCY=1
DELETION_CLEANUP_OBJECT_BATCH_SIZE=100
DELETION_CLEANUP_MAX_RETRIES=3
DELETION_CLEANUP_RETRY_BASE_DELAY_MS=1000
DELETION_CLEANUP_RETRY_BACKOFF=exponential
DELETION_CLEANUP_OPERATION_RETENTION_DAYS=
DELETION_CLEANUP_ITEM_RETENTION_DAYS=30

# Local example runtime limits.
# Tune these for your deployment before production use.
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_MAX_CONCURRENT_FILES=3
UPLOAD_DIRECT_ENABLED=false
UPLOAD_DIRECT_THRESHOLD_MB=50
UPLOAD_SESSION_EXPIRES_SECONDS=900
UPLOAD_MULTIPART_FALLBACK_MODE=enabled
UPLOAD_MULTIPART_TIMEOUT_SECONDS=300
UPLOAD_PRESSURE_DEGRADED_THRESHOLD=3
RUNTIME_QUEUE_DEPTH_DEGRADED_THRESHOLD=20
RUNTIME_QUEUE_DEPTH_SATURATED_THRESHOLD=100
COMPILE_QUEUE_DEPTH_DEGRADED_THRESHOLD=10
COMPILE_QUEUE_DEPTH_SATURATED_THRESHOLD=50
PROVIDER_FAILURE_DEGRADED_THRESHOLD=3
EXPENSIVE_VALIDATION_ENABLED=false
PARSER_MAX_FILE_SIZE_MB=50
PARSER_TIMEOUT_SECONDS=120
PARSER_CONCURRENCY=2
SOURCE_PARSE_CONCURRENCY=2
PARSER_ZIP_MAX_ENTRIES=10000
PARSER_ZIP_MAX_EXPANDED_MB=1000
PARSER_ZIP_MAX_ENTRY_MB=50
PARSER_MEDIA_UPLOAD_CONCURRENCY=2
PARSER_MAX_IMAGES_PER_DOCUMENT=50
PARSER_MAX_RENDERED_SNAPSHOTS_PER_DOCUMENT=10
PARSER_MAX_IMAGE_PIXELS=16000000
PARSER_MAX_IMAGE_BYTES=10485760
PARSER_MIN_IMAGE_WIDTH=64
PARSER_MIN_IMAGE_HEIGHT=64
PARSER_VISUAL_EXTRACTION_CONCURRENCY=2
PARSER_REMOTE_IMAGE_FETCHING_ENABLED=false
PARSER_PDF_SNAPSHOT_MIN_TEXT_CHARS=80
FOCOCONTEXT_QUEUE_CONCURRENCY=2
BATCH_IMPORT_CONCURRENCY=2
SOURCE_WATCH_SCAN_CONCURRENCY=2
SOURCE_WATCH_SCHEDULER_ENABLED=true
SOURCE_WATCH_SCAN_INTERVAL_SECONDS=3600
SOURCE_WATCH_SCAN_MAX_RETRIES=2
SOURCE_WATCH_SCAN_RETRY_BASE_DELAY_MS=1000
WIKI_ANALYZE_CONCURRENCY=2
WIKI_GENERATE_CONCURRENCY=2
WIKI_MERGE_CONCURRENCY=2

# Background job batch/checkpoint controls.
# These values bound long-running reindex, graph, check, watch, OCR, caption,
# and cleanup work. Increase gradually after observing CPU, Redis, DB, and provider limits.
BACKGROUND_REINDEX_BATCH_SIZE=100
BACKGROUND_REINDEX_CURSOR_WINDOW_SIZE=100
BACKGROUND_REINDEX_CHECKPOINT_INTERVAL=1
BACKGROUND_REINDEX_RETRY_BASE_DELAY_MS=1000
BACKGROUND_REINDEX_CONCURRENCY=2
BACKGROUND_GRAPH_INSIGHTS_BATCH_SIZE=100
BACKGROUND_GRAPH_INSIGHTS_CURSOR_WINDOW_SIZE=100
BACKGROUND_GRAPH_INSIGHTS_CHECKPOINT_INTERVAL=1
BACKGROUND_GRAPH_INSIGHTS_RETRY_BASE_DELAY_MS=1000
BACKGROUND_GRAPH_INSIGHTS_CONCURRENCY=2
BACKGROUND_KNOWLEDGE_CHECK_BATCH_SIZE=100
BACKGROUND_KNOWLEDGE_CHECK_CURSOR_WINDOW_SIZE=100
BACKGROUND_KNOWLEDGE_CHECK_CHECKPOINT_INTERVAL=1
BACKGROUND_KNOWLEDGE_CHECK_RETRY_BASE_DELAY_MS=1000
BACKGROUND_KNOWLEDGE_CHECK_CONCURRENCY=2
BACKGROUND_SOURCE_WATCH_BATCH_SIZE=100
BACKGROUND_SOURCE_WATCH_CURSOR_WINDOW_SIZE=100
BACKGROUND_SOURCE_WATCH_CHECKPOINT_INTERVAL=1
BACKGROUND_SOURCE_WATCH_RETRY_BASE_DELAY_MS=1000
BACKGROUND_SOURCE_WATCH_CONCURRENCY=2
BACKGROUND_OCR_BATCH_SIZE=20
BACKGROUND_OCR_CURSOR_WINDOW_SIZE=20
BACKGROUND_OCR_CHECKPOINT_INTERVAL=1
BACKGROUND_OCR_RETRY_BASE_DELAY_MS=1000
BACKGROUND_OCR_CONCURRENCY=1
BACKGROUND_MEDIA_CAPTION_BATCH_SIZE=50
BACKGROUND_MEDIA_CAPTION_CURSOR_WINDOW_SIZE=50
BACKGROUND_MEDIA_CAPTION_CHECKPOINT_INTERVAL=1
BACKGROUND_MEDIA_CAPTION_RETRY_BASE_DELAY_MS=1000
BACKGROUND_MEDIA_CAPTION_CONCURRENCY=1
BACKGROUND_CLEANUP_BATCH_SIZE=100
BACKGROUND_CLEANUP_CURSOR_WINDOW_SIZE=100
BACKGROUND_CLEANUP_CHECKPOINT_INTERVAL=1
BACKGROUND_CLEANUP_RETRY_BASE_DELAY_MS=1000
BACKGROUND_CLEANUP_CONCURRENCY=1

COMPILE_MAX_CONTEXT_CHARS=24000
RETRIEVE_DEFAULT_TOP_K=10
RETRIEVE_MAX_TOP_K=20
RETRIEVE_DEFAULT_GRAPH_DEPTH=1
RETRIEVE_MAX_GRAPH_DEPTH=3
RETRIEVE_DEFAULT_GRAPH_LIMIT_PER_RESULT=5
RETRIEVE_MAX_GRAPH_LIMIT_PER_RESULT=10
RETRIEVE_DEFAULT_CONTEXT_BUDGET_TOKENS=4000
RETRIEVE_MAX_CONTEXT_BUDGET_TOKENS=12000
SOURCE_EVIDENCE_DEFAULT_MAX_CHARS=4000
SOURCE_EVIDENCE_MAX_CHARS=12000
SOURCE_EVIDENCE_DEFAULT_CONTEXT_CHARS=800
SOURCE_EVIDENCE_MAX_CONTEXT_CHARS=2000
SOURCE_EVIDENCE_BATCH_MAX_ITEMS=20
SOURCE_EVIDENCE_BATCH_TOTAL_OUTPUT_MAX_CHARS=40000

# Webhook secret is optional in V0.1.
FOCOCONTEXT_WEBHOOK_SECRET=
WEBHOOK_DELIVERY_ENABLED=true
WEBHOOK_DELIVERY_TIMEOUT_SECONDS=10
WEBHOOK_DELIVERY_CONCURRENCY=2
WEBHOOK_DELIVERY_MAX_RETRIES=3
WEBHOOK_DELIVERY_RETRY_BASE_DELAY_MS=1000
WEBHOOK_DELIVERY_RETRY_BACKOFF=exponential
WEBHOOK_SIGNING_TOLERANCE_SECONDS=300
WEBHOOK_DELIVERY_RETENTION_DAYS=30
