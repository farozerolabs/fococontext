{
  "name": "fococontext",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "docs:build": "pnpm --filter @fococontext/docs-site build",
    "docs:dev": "pnpm --filter @fococontext/docs-site dev",
    "docs:preview": "pnpm --filter @fococontext/docs-site preview",
    "docs:validate": "pnpm --filter @fococontext/docs-site docs:validate",
    "docker:cleanup": "node scripts/docker-cleanup.mjs",
    "docker:up": "node scripts/docker-dev-up.mjs",
    "docker:up:ocr": "node scripts/docker-dev-up.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false",
    "validation:white-box": "node scripts/validation/white-box-real-data-validation.mjs",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
